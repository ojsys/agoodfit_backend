# ─── Copy this file to .env and fill in your values ─────────────────────────
# This .env file is only used by production.py (on the cPanel server).
# Development uses SQLite with no .env needed.

# Django
SECRET_KEY=your-long-random-secret-key-here
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# MySQL database (created in cPanel → MySQL Databases)
DB_NAME=cpanelusername_dbname
DB_USER=cpanelusername_dbuser
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=3306

# CSRF — your domain(s) with https scheme
CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Redis (optional — leave blank, app works without it)
REDIS_URL=

# Email (optional — for password resets)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your@email.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# Firebase push notifications (optional)
FCM_SERVER_KEY=

# Set to True only if Django should redirect HTTP→HTTPS itself.
# Leave False if cPanel/Apache already handles SSL (most common).
SECURE_SSL_REDIRECT=False
