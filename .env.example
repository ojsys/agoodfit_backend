# ─── Copy this file to .env and fill in your values ─────────────────────────

# Django
SECRET_KEY=your-long-random-secret-key-here
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# Database — set DB_ENGINE to postgresql or mysql (leave blank for sqlite dev)
DB_ENGINE=mysql
DB_NAME=cpanel_db_name
DB_USER=cpanel_db_user
DB_PASSWORD=cpanel_db_password
DB_HOST=localhost
DB_PORT=3306

# CORS — comma-separated list of allowed frontend origins
# For a mobile app you can leave this blank (mobile apps don't send Origin headers)
CORS_ALLOWED_ORIGINS=

# CSRF — your domain(s) with scheme
CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Redis (optional — leave blank to use in-memory fallback)
REDIS_URL=

# Email (optional — used for password resets etc.)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your@email.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# Firebase push notifications (optional)
FCM_SERVER_KEY=

# Force HTTPS redirect (set to False if cPanel handles SSL termination)
SECURE_SSL_REDIRECT=False
